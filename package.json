{
  "name": "rocq-vine-boom",
  "displayName": "rocq-vine-boom",
  "description": "VSCode extension I made for fun, that plays a Vine boom sound when a proof goes wrong.",
  "repository": "https://github.com/s-feles/rocq-vine-boom",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [ "onLanguage:rocq" ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rocq-vine-boom.testSound",
        "title": "Test Sound"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}
